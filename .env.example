# ─── Neon Postgres ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.aws.neon.tech/dbname?sslmode=require

# ─── Google Drive (OAuth user creds) ───────────────────────────────────────
# Run `python oauth_setup.py` ONCE locally to mint a refresh token, then copy
# these values out of credentials/oauth_client.json + credentials/oauth_token.json:
GOOGLE_OAUTH_CLIENT_ID=xxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=xxxxxx
GOOGLE_OAUTH_REFRESH_TOKEN=1//xxxxxx
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# ─── Scrape range ──────────────────────────────────────────────────────────
INPUT_CSV_FILENAME=entities.csv
SCRAPE_START_ROW=0
SCRAPE_END_ROW=500
AUTO_START_SCRAPE=true
RATE_LIMIT_MIN=3
RATE_LIMIT_MAX=10
