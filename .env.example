# ─── Database ───────────────────────────────────────────────────────────────
# PRIMARY (required) — writes here MUST succeed. Reads come from here too.
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/market_leads?sslmode=require

# SECONDARY (optional) — every successful primary write is also mirrored here.
# Failures on the secondary are logged, never fatal.
# In docker compose: hostname `postgres` is the sibling container.
SECONDARY_DATABASE_URL=postgresql://recordowl:recordowl@postgres:5432/recordowl

# ─── Scraping Range ─────────────────────────────────────────────────────────
INPUT_CSV_FILENAME=entities.csv
SCRAPE_START_ROW=0
SCRAPE_END_ROW=500

# ─── Google Drive (OAuth user credentials) ─────────────────────────────────
# Created once via `python oauth_setup.py` — see the script's docstring.
# Uploads count against the signed-in user's 15 GB Drive quota.
GOOGLE_OAUTH_CLIENT_FILE=credentials/oauth_client.json
GOOGLE_OAUTH_TOKEN_FILE=credentials/oauth_token.json
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id-here

# ─── Cookies ───────────────────────────────────────────────────────────────
COOKIE_FILE=.cookies/recordowl-cookies.json

# ─── Auto-start ────────────────────────────────────────────────────────────
AUTO_START_SCRAPE=true

# ─── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_MIN=3
RATE_LIMIT_MAX=10
